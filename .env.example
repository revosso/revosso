# Revosso Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE - Turso (LibSQL/SQLite)
# ===========================================
# Get these from https://turso.tech
# 1. Create a database
# 2. Copy the URL and auth token
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ===========================================
# EMAIL - SMTP Configuration
# ===========================================
# For Gmail: Enable 2FA and create an App Password
# For SendGrid: Use API key
# For other providers: Check their SMTP documentation

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=noreply@revosso.com

# ===========================================
# ADMIN
# ===========================================
# Email address to receive lead notifications
ADMIN_EMAIL=admin@revosso.com

# ===========================================
# LANDING — Calendly (optional)
# ===========================================
# Public URL for booking a call (e.g. https://calendly.com/your-org/discovery).
# When set, “Discuss your project” CTAs open this link; the final section also shows “Schedule a meeting”.
NEXT_PUBLIC_CALENDLY_URL=

# ===========================================
# OPTIONAL - Next.js
# ===========================================
NODE_ENV=development
