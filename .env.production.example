# Production environment template (Docker / Dockploy)
# Copy to .env.production and set real values, or inject the same variables via your platform.

# ===========================================
# DATABASE - Turso (LibSQL/SQLite)
# ===========================================
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ===========================================
# EMAIL - SMTP Configuration
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=noreply@revosso.com

# ===========================================
# ADMIN
# ===========================================
ADMIN_EMAIL=admin@revosso.com

# ===========================================
# Next.js / Node
# ===========================================
NODE_ENV=production

# Skip DB migrations on container start (e.g. if you run migrations in CI)
# SKIP_DB_MIGRATE_ON_START=1
